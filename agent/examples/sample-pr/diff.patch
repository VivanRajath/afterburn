 import logging
 from typing import Optional
 from sqlalchemy.orm import Session
+from sqlalchemy import text
 from .models import PaymentRecord
 from .exceptions import PaymentProcessingError

@@ -14,10 +15,24 @@ class PaymentHandler:

     def process(self, event: dict) -> None:
         charge_id = event.get("charge")
         if not charge_id:
             raise ValueError("Payment event missing charge id")
-        existing = self.db.query(PaymentRecord).filter_by(stripe_charge_id=charge_id).first()
+        existing = self.db.query(PaymentRecord).filter(
+            PaymentRecord.stripe_charge_id == charge_id
+        ).first()
         if existing:
             return
+
+    def handle_refund(self, event: dict) -> Optional[PaymentRecord]:
+        """Handle Stripe charge.refunded events."""
+        charge_id = event.get("data", {}).get("object", {}).get("charge")
+        if not charge_id:
+            raise PaymentProcessingError("refund event missing charge id")
+        record = self.db.query(PaymentRecord).filter_by(
+            stripe_charge_id=charge_id
+        ).first()
+        if not record:
+            logging.warning("refund for unknown charge %s", charge_id)
+            return None
+        record.status = "refunded"
+        self.db.commit()
+        return record
