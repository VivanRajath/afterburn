# afterburn environment variables
# Copy this file to .env and fill in values before running.
# .env is gitignored and must never be committed.

# ── GitHub ────────────────────────────────────────────────────────────────────

# Required. Personal access token for PR diff fetching and comment posting.
# Minimum scope: read:pull_requests, write:discussion.
GITHUB_TOKEN=

# ── Memory backend ────────────────────────────────────────────────────────────

# Optional. Active memory adapter. Default: cognis.
# Valid values: cognis | filesystem | sqlite | s3
AFTERBURN_MEMORY_BACKEND=cognis

# ── Cognis (default backend) ──────────────────────────────────────────────────

# Required if AFTERBURN_MEMORY_BACKEND=cognis.
# Your Lyzr API key from memory.studio.lyzr.ai.
LYZR_API_KEY=

# Required if AFTERBURN_MEMORY_BACKEND=cognis.
# Cognis namespace. Default per Cognis README: $(whoami).
# Use your org name for shared team deployments.
COGNIS_OWNER_ID=

# Optional if AFTERBURN_MEMORY_BACKEND=cognis.
# Override the Cognis API endpoint. Default: https://memory.studio.lyzr.ai
# COGNIS_API_URL=https://memory.studio.lyzr.ai

# ── Filesystem backend (alternative) ─────────────────────────────────────────

# Required if AFTERBURN_MEMORY_BACKEND=filesystem.
# Absolute path to the root directory for incident and lesson files.
# AFTERBURN_FS_ROOT=/var/afterburn/memory

# ── SQLite backend (alternative) ──────────────────────────────────────────────

# Required if AFTERBURN_MEMORY_BACKEND=sqlite.
# Absolute path to the SQLite database file.
# AFTERBURN_SQLITE_PATH=/var/afterburn/afterburn.db

# ── S3 backend (alternative) ──────────────────────────────────────────────────

# Required if AFTERBURN_MEMORY_BACKEND=s3.
# AFTERBURN_S3_BUCKET=my-afterburn-bucket
# AFTERBURN_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional if AFTERBURN_MEMORY_BACKEND=s3.
# Override S3 endpoint (for MinIO or other S3-compatible stores).
# AFTERBURN_S3_ENDPOINT=
